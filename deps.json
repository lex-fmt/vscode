{
  "lexd-lsp": {
    "repo": "lex-fmt/lex",
    "version": "v0.17.0",
    "asset": "lexd-lsp-{{target}}{{ext}}",
    "binary": "lexd-lsp",
    "dest": "resources"
  },
  "tree-sitter": {
    "repo": "lex-fmt/tree-sitter-lex",
    "version": "v0.11.0",
    "asset": "tree-sitter.tar.gz",
    "extract": {
      "tree-sitter-lex.wasm": "resources",
      "queries": "resources/queries",
      "shared/embedded-grammars.json": "resources"
    }
  },
  "embedded-grammars": {
    "from-manifest": "resources/embedded-grammars.json",
    "for-each": ".grammars[]",
    "repo": "{{.repo}}",
    "version": "{{.version}}",
    "asset": "{{.wasm_asset}}",
    "dest": "resources/embedded-grammars/{{.name}}",
    "binary-as": "parser.wasm",
    "raw-files": {
      "{{.queries_path}}": "highlights.scm"
    }
  }
}
