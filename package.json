{
  "name": "lex-vscode",
  "displayName": "Lex Format",
  "description": "Language support for Lex documents via lex-lsp.",
  "version": "0.0.0-dev",
  "publisher": "lex",
  "license": "MIT",
  "icon": "comms/assets/logo@128.png",
  "type": "module",
  "private": true,
  "main": "./out/src/main.cjs",
  "engines": {
    "vscode": "^1.106.0",
    "node": ">=20"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lex"
  ],
  "contributes": {
    "commands": [
      {
        "command": "lex.showPreview",
        "title": "Open Preview",
        "category": "Lex",
        "icon": "$(open-preview)"
      },
      {
        "command": "lex.showPreviewToSide",
        "title": "Open Preview to the Side",
        "category": "Lex",
        "icon": "$(open-preview)"
      },
      {
        "command": "lex.exportToMarkdown",
        "title": "Export to Markdown",
        "category": "Lex"
      },
      {
        "command": "lex.exportToHtml",
        "title": "Export to HTML",
        "category": "Lex"
      },
      {
        "command": "lex.convertToLex",
        "title": "Convert to Lex",
        "category": "Lex"
      },
      {
        "command": "lex.exportToPdf",
        "title": "Export to PDF",
        "category": "Lex"
      },
      {
        "command": "lex.insertAssetReference",
        "title": "Insert Asset Reference",
        "category": "Lex"
      },
      {
        "command": "lex.insertVerbatimBlock",
        "title": "Insert Verbatim Block from File",
        "category": "Lex"
      },
      {
        "command": "lex.goToNextAnnotation",
        "title": "Go to Next Annotation",
        "category": "Lex"
      },
      {
        "command": "lex.goToPreviousAnnotation",
        "title": "Go to Previous Annotation",
        "category": "Lex"
      },
      {
        "command": "lex.resolveAnnotation",
        "title": "Resolve Annotation",
        "category": "Lex"
      },
      {
        "command": "lex.toggleAnnotationResolution",
        "title": "Toggle Annotation Resolution",
        "category": "Lex"
      },
      {
        "command": "lex.formatTable",
        "title": "Format Table",
        "category": "Lex"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "lex.showPreview",
          "when": "editorLangId == lex"
        },
        {
          "command": "lex.showPreviewToSide",
          "when": "editorLangId == lex"
        },
        {
          "command": "lex.exportToMarkdown",
          "when": "editorLangId == lex"
        },
        {
          "command": "lex.exportToHtml",
          "when": "editorLangId == lex"
        },
        {
          "command": "lex.convertToLex",
          "when": "editorLangId == markdown"
        },
        {
          "command": "lex.exportToPdf",
          "when": "editorLangId == lex"
        },
        {
          "command": "lex.formatTable",
          "when": "editorLangId == lex"
        }
      ],
      "editor/context": [
        {
          "command": "lex.showPreviewToSide",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToMarkdown",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToHtml",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.convertToLex",
          "when": "editorLangId == markdown",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToPdf",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.insertAssetReference",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.insertVerbatimBlock",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.goToNextAnnotation",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.goToPreviousAnnotation",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.resolveAnnotation",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.toggleAnnotationResolution",
          "when": "editorLangId == lex",
          "group": "1_modification"
        },
        {
          "command": "lex.formatTable",
          "when": "editorLangId == lex",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "lex.showPreviewToSide",
          "when": "editorLangId == lex",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "lex.showPreviewToSide",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToMarkdown",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToHtml",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        },
        {
          "command": "lex.convertToLex",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToPdf",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        }
      ],
      "explorer/context": [
        {
          "command": "lex.showPreviewToSide",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToMarkdown",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToHtml",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        },
        {
          "command": "lex.convertToLex",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        },
        {
          "command": "lex.exportToPdf",
          "when": "resourceExtname == .lex",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lex.table.nextCell",
        "key": "tab",
        "when": "editorLangId == lex && lex.inTableCell"
      },
      {
        "command": "lex.table.previousCell",
        "key": "shift+tab",
        "when": "editorLangId == lex && lex.inTableCell"
      },
      {
        "command": "lex.formatTable",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorLangId == lex"
      }
    ],
    "iconThemes": [
      {
        "id": "lex-icons",
        "label": "Lex File Icons",
        "path": "./icons/lex-file-icon-theme.json"
      }
    ],
    "languages": [
      {
        "id": "lex",
        "aliases": [
          "Lex"
        ],
        "extensions": [
          ".lex"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "DocumentTitle",
        "description": "Document title"
      },
      {
        "id": "DocumentSubtitle",
        "description": "Document subtitle"
      },
      {
        "id": "SessionMarker",
        "description": "Session marker"
      },
      {
        "id": "SessionTitleText",
        "description": "Session title text"
      },
      {
        "id": "DefinitionSubject",
        "description": "Definition subject/term"
      },
      {
        "id": "DefinitionContent",
        "description": "Definition content"
      },
      {
        "id": "ListMarker",
        "description": "List item marker"
      },
      {
        "id": "ListItemText",
        "description": "List item text"
      },
      {
        "id": "AnnotationLabel",
        "description": "Annotation label"
      },
      {
        "id": "AnnotationParameter",
        "description": "Annotation parameter"
      },
      {
        "id": "AnnotationContent",
        "description": "Annotation content"
      },
      {
        "id": "InlineStrong",
        "description": "Strong/bold text"
      },
      {
        "id": "InlineEmphasis",
        "description": "Emphasized/italic text"
      },
      {
        "id": "InlineCode",
        "description": "Inline code"
      },
      {
        "id": "InlineMath",
        "description": "Inline math"
      },
      {
        "id": "Reference",
        "description": "Reference"
      },
      {
        "id": "ReferenceCitation",
        "description": "Citation reference"
      },
      {
        "id": "ReferenceFootnote",
        "description": "Footnote reference"
      },
      {
        "id": "VerbatimSubject",
        "description": "Verbatim block subject"
      },
      {
        "id": "VerbatimLanguage",
        "description": "Verbatim language identifier"
      },
      {
        "id": "VerbatimAttribute",
        "description": "Verbatim attribute"
      },
      {
        "id": "VerbatimContent",
        "description": "Verbatim content"
      },
      {
        "id": "InlineMarker_strong_start",
        "description": "Strong/bold opening marker"
      },
      {
        "id": "InlineMarker_strong_end",
        "description": "Strong/bold closing marker"
      },
      {
        "id": "InlineMarker_emphasis_start",
        "description": "Emphasis/italic opening marker"
      },
      {
        "id": "InlineMarker_emphasis_end",
        "description": "Emphasis/italic closing marker"
      },
      {
        "id": "InlineMarker_code_start",
        "description": "Inline code opening marker"
      },
      {
        "id": "InlineMarker_code_end",
        "description": "Inline code closing marker"
      },
      {
        "id": "InlineMarker_math_start",
        "description": "Inline math opening marker"
      },
      {
        "id": "InlineMarker_math_end",
        "description": "Inline math closing marker"
      },
      {
        "id": "InlineMarker_ref_start",
        "description": "Reference opening bracket"
      },
      {
        "id": "InlineMarker_ref_end",
        "description": "Reference closing bracket"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "lex",
        "scopes": {
          "DocumentTitle": [
            "markup.heading",
            "entity.name.section"
          ],
          "DocumentSubtitle": [
            "markup.heading",
            "entity.name.section"
          ],
          "SessionMarker": [
            "punctuation.definition.heading"
          ],
          "SessionTitleText": [
            "markup.heading"
          ],
          "DefinitionSubject": [
            "variable.other.definition"
          ],
          "DefinitionContent": [
            "text"
          ],
          "ListMarker": [
            "punctuation.definition.list"
          ],
          "ListItemText": [
            "markup.list"
          ],
          "AnnotationLabel": [
            "comment.block"
          ],
          "AnnotationParameter": [
            "variable.parameter"
          ],
          "AnnotationContent": [
            "comment.block"
          ],
          "InlineStrong": [
            "markup.bold"
          ],
          "InlineEmphasis": [
            "markup.italic"
          ],
          "InlineCode": [
            "markup.inline.raw"
          ],
          "InlineMath": [
            "constant.numeric"
          ],
          "Reference": [
            "markup.underline.link"
          ],
          "ReferenceCitation": [
            "markup.underline.link"
          ],
          "ReferenceFootnote": [
            "markup.underline.link"
          ],
          "VerbatimSubject": [
            "entity.name.section"
          ],
          "VerbatimLanguage": [
            "entity.name.tag"
          ],
          "VerbatimAttribute": [
            "variable.parameter"
          ],
          "VerbatimContent": [
            "markup.raw.block"
          ],
          "InlineMarker_strong_start": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_strong_end": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_emphasis_start": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_emphasis_end": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_code_start": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_code_end": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_math_start": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_math_end": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_ref_start": [
            "punctuation.definition.inline"
          ],
          "InlineMarker_ref_end": [
            "punctuation.definition.inline"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Lex",
      "properties": {
        "lex.lspBinaryPath": {
          "type": "string",
          "markdownDescription": "Absolute or workspace-relative path to the lex-lsp binary.",
          "default": "./resources/lex-lsp"
        },
        "lex.formatOnSave": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Automatically format Lex documents when saving. Formatting rules are configured in `.lex.toml`."
        },
        "lex.injectionHighlighting": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable syntax highlighting for embedded code in verbatim blocks (e.g., Python, JavaScript). Uses tree-sitter to detect language annotations."
        }
      }
    },
    "colors": [
      {
        "id": "lex.injection.keyword",
        "description": "Color for keywords in embedded code blocks",
        "defaults": {
          "dark": "#569cd6",
          "light": "#0000ff",
          "highContrast": "#569cd6",
          "highContrastLight": "#0000ff"
        }
      },
      {
        "id": "lex.injection.string",
        "description": "Color for strings in embedded code blocks",
        "defaults": {
          "dark": "#ce9178",
          "light": "#a31515",
          "highContrast": "#ce9178",
          "highContrastLight": "#a31515"
        }
      },
      {
        "id": "lex.injection.comment",
        "description": "Color for comments in embedded code blocks",
        "defaults": {
          "dark": "#6a9955",
          "light": "#008000",
          "highContrast": "#7ca668",
          "highContrastLight": "#008000"
        }
      },
      {
        "id": "lex.injection.number",
        "description": "Color for numeric literals in embedded code blocks",
        "defaults": {
          "dark": "#b5cea8",
          "light": "#098658",
          "highContrast": "#b5cea8",
          "highContrastLight": "#098658"
        }
      },
      {
        "id": "lex.injection.type",
        "description": "Color for type names in embedded code blocks",
        "defaults": {
          "dark": "#4ec9b0",
          "light": "#267f99",
          "highContrast": "#4ec9b0",
          "highContrastLight": "#267f99"
        }
      },
      {
        "id": "lex.injection.function",
        "description": "Color for function names in embedded code blocks",
        "defaults": {
          "dark": "#dcdcaa",
          "light": "#795e26",
          "highContrast": "#dcdcaa",
          "highContrastLight": "#795e26"
        }
      },
      {
        "id": "lex.injection.operator",
        "description": "Color for operators in embedded code blocks",
        "defaults": {
          "dark": "#d4d4d4",
          "light": "#000000",
          "highContrast": "#d4d4d4",
          "highContrastLight": "#000000"
        }
      }
    ],
    "configurationDefaults": {
      "[lex]": {
        "editor.defaultFormatter": "lex.lex-vscode",
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "SessionTitleText:lex": {
            "foreground": "#e0e0e0",
            "fontStyle": "bold"
          },
          "DefinitionSubject:lex": {
            "foreground": "#e0e0e0",
            "fontStyle": "italic"
          },
          "DefinitionContent:lex": "#e0e0e0",
          "InlineStrong:lex": {
            "foreground": "#e0e0e0",
            "fontStyle": "bold"
          },
          "InlineEmphasis:lex": {
            "foreground": "#e0e0e0",
            "fontStyle": "italic"
          },
          "InlineCode:lex": "#e0e0e0",
          "InlineMath:lex": {
            "foreground": "#e0e0e0",
            "fontStyle": "italic"
          },
          "VerbatimContent:lex": "#e0e0e0",
          "ListItemText:lex": "#e0e0e0",
          "DocumentTitle:lex": {
            "foreground": "#e0e0e0",
            "fontStyle": "bold underline"
          },
          "DocumentSubtitle:lex": {
            "foreground": "#e0e0e0",
            "fontStyle": "italic"
          },
          "SessionMarker:lex": {
            "foreground": "#888888",
            "fontStyle": "italic"
          },
          "ListMarker:lex": {
            "foreground": "#888888",
            "fontStyle": "italic"
          },
          "Reference:lex": {
            "foreground": "#888888",
            "fontStyle": "underline"
          },
          "ReferenceCitation:lex": {
            "foreground": "#888888",
            "fontStyle": "underline"
          },
          "ReferenceFootnote:lex": {
            "foreground": "#888888",
            "fontStyle": "underline"
          },
          "AnnotationLabel:lex": "#666666",
          "AnnotationParameter:lex": "#666666",
          "AnnotationContent:lex": "#666666",
          "VerbatimSubject:lex": "#666666",
          "VerbatimLanguage:lex": "#666666",
          "VerbatimAttribute:lex": "#666666",
          "InlineMarker_strong_start:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_strong_end:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_emphasis_start:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_emphasis_end:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_code_start:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_code_end:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_math_start:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_math_end:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_ref_start:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          },
          "InlineMarker_ref_end:lex": {
            "foreground": "#555555",
            "fontStyle": "italic"
          }
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -watch -p .",
    "copy-wasm": "cp node_modules/web-tree-sitter/tree-sitter.wasm resources/tree-sitter.wasm",
    "bundle": "npm run copy-wasm && esbuild src/main.ts --bundle --outfile=out/src/main.cjs --external:vscode --format=cjs --platform=node --target=node20",
    "vscode:prepublish": "npm run bundle -- --minify",
    "pretest": "npm run build && npm run bundle",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node ./out/test/unit/index.js",
    "test:integration": "node ./out/test/runTests.js",
    "test:vsix": "npm run build && npm run bundle && node ./out/test/runVsixSmoke.js",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "build:vsix": "bash ./scripts/build-vsix.sh",
    "build:vsix:openvsx": "bash ./scripts/build-vsix.sh --openvsx",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lex-lang/lex.git"
  },
  "dependencies": {
    "@lex/shared": "file:./shared",
    "vscode-languageclient": "^9.0.1",
    "web-tree-sitter": "^0.25.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.25",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.23.1",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
