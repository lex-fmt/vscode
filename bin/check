#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

_lefthook=""
if [ -x node_modules/.bin/lefthook ]; then
  _lefthook="node_modules/.bin/lefthook"
elif command -v lefthook >/dev/null 2>&1; then
  _lefthook="lefthook"
else
  echo "error: lefthook not found (install: npm install -g lefthook)" >&2
  exit 1
fi

"$_lefthook" run pre-commit --all-files --no-tty

"$SCRIPT_DIR/check-tests"

echo ""
echo "All checks passed!"
