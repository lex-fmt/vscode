#!/usr/bin/env bash
# install-release-core — the boot resolver for the pull-model distribution.
#
# Installs the release_core wheel into its OWN isolated venv and exposes its
# console-scripts on PATH. This is THE single definition of "how a repo gets the
# current release_core" (ADR-0003). Both boot contexts call it: the SessionStart
# hook (setup-dev-env.sh) and the reusable CI workflows. It runs BEFORE
# release_core is installed, so it is pure shell — it cannot itself be a
# release_core console-script.
#
# Install model (WS3, release#760) — INDEX-FIRST with an ASSET-PATH FALLBACK:
#   1. Determine the MAJOR line: read `.release.major.txt` (the committed
#      single-source release-core LOGIC version; seeded by `release-core init`).
#      When that file is absent (a not-yet-migrated consumer), fall back to
#      `derive_caller_major` — the `@vN` thin-caller grep — for the boot window.
#   2. INDEX path: `pip install --extra-index-url <pages-index> 'release-core>=N,<N+1'`.
#      The WS2 GitHub-Pages PEP 503 index serves real tag-stamped wheels
#      (release#758/#759); pip version-compares and installs the newest in the
#      major line. PyPI stays PRIMARY (--extra-index-url, not --index-url) so
#      release_core's own deps (click) resolve from PyPI.
#   3. ASSET-PATH FALLBACK: if the index install fails to resolve a usable wheel
#      (the index is empty until this epic ships to main + a release cuts — every
#      EXISTING wheel is the static release_core-0.0.1, so the index is useless
#      until a real-stamped wheel is published), fall back to the EXISTING
#      release-asset resolver (`resolve_url` over the GitHub releases API) and
#      install that wheel URL with --force-reinstall. UNCHANGED behavior — this is
#      the transitional path that keeps the boot working through Phase 1. Both
#      resolve_url/_resolve_url_list and this fallback are removed in WS8.
#
# Why --force-reinstall ONLY on the asset-path fallback: the asset path installs a
# SPECIFIC wheel URL (no version compare), so --force-reinstall is what re-lands
# the current managed tree on a re-run (pull-model self-sync) — its long-standing
# behavior, kept intact. The INDEX path version-compares, so a plain
# `pip install '<constraint>'` already upgrades to the newest matching wheel; we
# do NOT force-reinstall there (a no-op reinstall every boot is wasteful and the
# version compare already does the right thing). NO --no-deps on either: click is
# pure-Python, resolved from PyPI on each boot.
#
# --from-source (load-bearing for release's own CI / canary) is unchanged: a LOCAL
# path install, no release resolution, no network.
#
# FAIL-LOUD (WS6/F, release#763): the wheel pull is the FOUNDATION — no wheel ⇒ no
# `release-core gate --hook` ⇒ no gate at all. So a pull failure HALTS this resolver
# LOUDLY (non-zero exit, a clear root-cause message), never a silent half-state. But
# halt only AFTER a bounded transient-retry (`retry`, below: 3 attempts, short
# backoff) — a 1-second network/`gh`/pip hiccup must NOT red-alert a session. The
# network calls (the pip installs, the gh-API resolve) run THROUGH `retry`; only a
# still-failing pull after the retries aborts. This script's own `set -e` + the
# explicit `exit 1` on an unresolvable wheel are the halt; the SessionStart caller
# (setup-dev-env.sh §0.1) DROPS its old `|| warn` so the halt actually surfaces.
# init + gate wiring downstream stay best-effort (the committed tree degrades
# gracefully); only the load-bearing PULL is fail-loud.
#
# After installing, this runs `release-core init` in the current repo by default
# (--no-init to skip) — the "one command does the boot" ergonomic. A bare `init`
# installs the WHOLE set of managed files from the wheel bundle (the .release/
# temp dir + every working-tree mirror — skills, configs, .claude/IMPORTANT-RELEASE.md
# + the CLAUDE.md @import, and — WS3 — seeds `.release.major.txt`) and auto-commits
# managed changes (#476 cutover). This is the pull-model self-sync: the wheel pull
# carries the whole set, so no push is needed. init is best-effort — its failure
# does NOT fail the resolver.
#
# Source of truth: arthur-debert/release bin/install-release-core. Sister to
# install-release-token / install-release-secrets.

set -euo pipefail

REPO="arthur-debert/release"
MAJOR=""
PRINT_URL=0
NO_INIT=0
CLOUD=0          # forward --cloud to `release-core init` (cloud-only provisioning:
                 # tag fetch, dep caches, NSS cert import — WS5/E). Set by the cloud
                 # SessionStart boot (setup-dev-env.sh).
FROM_SOURCE=""   # install from a LOCAL path (a checkout's release_core source)
                 # instead of a published wheel — same venv/PATH machinery.
PYTHON="${PYTHON:-python3}"   # interpreter used to BUILD the isolated tool venv

# The WS2 GitHub-Pages PEP 503 "simple" pip index (release#759). Served at the
# dedicated custom domain pypi.magik.works (release#772): the account's user-site
# custom domain redirects arthur-debert.github.io/* to a Vercel site, so the repo
# carries its own per-repo Pages domain to escape that redirect. PyPI stays the
# PRIMARY index (we pass this as --extra-index-url), so release_core's own deps
# resolve from PyPI; this index serves only the release_core wheels.
PIP_INDEX_URL="${RELEASE_CORE_PIP_INDEX:-https://pypi.magik.works/simple/}"

# release_core lives in its OWN dedicated venv — never the user's pip, the system
# site-packages, or a project venv (no `pip --user`, no PEP-668 system writes).
# Its console-scripts are exposed on PATH via symlinks into BIN_DIR. This is the
# pipx model, hand-rolled so it needs no pipx (portable to local, cloud, CI).
# `python -m venv` builds an independent env even when $PYTHON is itself a venv,
# so a quirky `python3` (e.g. one that resolves into a pipx venv) no longer breaks
# the install the way `pip --user` did (rejected inside a venv).
VENV_DIR="${RELEASE_CORE_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/release-core}/venv"
BIN_DIR="${XDG_BIN_HOME:-$HOME/.local/bin}"

# Bounded transient-retry around a load-bearing network call (WS6/F, release#763).
# Fail-loud must HALT on a real failure but NOT on a 1-second blip, so the network
# calls (pip installs, the gh-API resolve) run through this: up to RETRY_ATTEMPTS
# tries with a short, growing backoff; returns the LAST attempt's exit code so the
# caller still fails loud when every attempt failed. Overridable for tests via
# RETRY_ATTEMPTS / RETRY_SLEEP (set RETRY_SLEEP=0 to make tests instant).
RETRY_ATTEMPTS="${RETRY_ATTEMPTS:-3}"
RETRY_SLEEP="${RETRY_SLEEP:-2}"
retry() {
  _attempt=1
  while :; do
    # Capture the command's exit code directly (NOT via `if cmd; then`: a failed
    # `if` condition leaves $? = 0, so the rc would always read as 0 — the bug a
    # naive `if "$@"; then return 0; fi; _rc=$?` form hides). `&& _rc=0 || _rc=$?`
    # records the real status while keeping `set -e` happy.
    "$@" && _rc=0 || _rc=$?
    if [ "$_rc" -eq 0 ]; then
      return 0
    fi
    if [ "$_attempt" -ge "$RETRY_ATTEMPTS" ]; then
      echo "install-release-core: command failed after ${RETRY_ATTEMPTS} attempt(s) (rc=${_rc}): $*" >&2
      return "$_rc"
    fi
    echo "install-release-core: attempt ${_attempt}/${RETRY_ATTEMPTS} failed (rc=${_rc}); retrying in $(( RETRY_SLEEP * _attempt ))s — transient?" >&2
    sleep "$(( RETRY_SLEEP * _attempt ))"
    _attempt=$(( _attempt + 1 ))
  done
}

usage() {
  cat <<'EOF'
Usage: install-release-core [--major vN] [--repo OWNER/REPO] [--print-url]
                            [--from-source PATH] [--no-init]

Install release_core into its OWN isolated venv and expose its console-scripts on
PATH, then run `release-core init` in the current repo. The package comes from the
pip index (WS2) at the consumer's major line by default — with a transitional
GitHub-release-asset fallback — or from a LOCAL source tree with --from-source.

Options:
  --major vN        Pin to major line vN (e.g. --major v2). Default: read from
                    .release.major.txt, else derived from this repo's @vN callers.
  --repo OWNER/REPO Source repo for the release-asset fallback
                    (default: arthur-debert/release).
  --from-source PATH
                    Install release_core from a LOCAL path instead of the index —
                    for release's own CI, which must test the code in the current
                    checkout. PATH may be a release checkout ROOT (the nested
                    templates/commons/lib/release_core package dir is located
                    automatically) or the package dir itself. Skips index/release
                    resolution (no gh/network). Mutually exclusive with --major/--repo.
  --print-url       Print the resolved source (the --from-source path, or the
                    asset-fallback wheel URL) and exit (resolve only, no install).
  --no-init         Install only; do NOT run `release-core init` afterwards
                    (pure-transport mode, e.g. just updating the package).
  --cloud           Forward --cloud to `release-core init` so it runs the
                    cloud-only provisioning steps (tag fetch, dep caches, NSS cert
                    import). Set by the cloud SessionStart boot; no-op locally.
  -h, --help        Show this help.

Env:
  PYTHON                 Interpreter used to BUILD the tool venv (default: python3).
  RELEASE_CORE_HOME      Override the tool-venv parent dir (default:
                         ${XDG_DATA_HOME:-~/.local/share}/release-core).
  RELEASE_CORE_PIP_INDEX Override the pip index URL (default: the GitHub-Pages index).
  XDG_BIN_HOME           Where console-scripts are symlinked (default: ~/.local/bin).
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --major)
      [ $# -ge 2 ] || { echo "install-release-core: --major needs a value (e.g. v2)" >&2; exit 64; }
      MAJOR="$2"; shift 2 ;;
    --major=*) MAJOR="${1#--major=}"; shift ;;
    --repo)
      [ $# -ge 2 ] || { echo "install-release-core: --repo needs a value" >&2; exit 64; }
      REPO="$2"; shift 2 ;;
    --repo=*) REPO="${1#--repo=}"; shift ;;
    --print-url) PRINT_URL=1; shift ;;
    --from-source)
      [ $# -ge 2 ] || { echo "install-release-core: --from-source needs a PATH" >&2; exit 64; }
      FROM_SOURCE="$2"; shift 2 ;;
    --from-source=*) FROM_SOURCE="${1#--from-source=}"; shift ;;
    --no-init) NO_INIT=1; shift ;;
    --cloud) CLOUD=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "install-release-core: unknown argument '$1'" >&2; usage >&2; exit 64 ;;
  esac
done

# Transitional FALLBACK (removed in WS8): derive the major line from THIS repo's
# thin callers (release#551): `uses: <repo>/...@vN` in .github/workflows/ IS the
# consumer's pin declaration. The HIGHEST major wins: consumers legitimately mix
# lines (copilot-review.yml stayed @v1 while the stack workflows moved on), and a
# mid-migration repo should follow the line it is moving TO. No callers / no
# workflows dir → empty. Same self-deciding-from-the-checkout pattern as arm-gate's
# action_ref pin (release#541). Pre-WS3 this WAS the major source; now
# `.release.major.txt` is, and this only fires when that file is still absent.
derive_caller_major() {
  [ -d .github/workflows ] || return 0
  grep -rhoE "${REPO}/[^@\"']*@v[0-9]+" .github/workflows 2>/dev/null \
    | sed 's/.*@v//' \
    | sort -n \
    | tail -n1 \
    | sed 's/^/v/'
}

# Determine the MAJOR line (WS3, release#760). Precedence, when no explicit --major
# and not --from-source:
#   1. `.release.major.txt` — the committed single source for the release-core
#      LOGIC version (a bare integer, e.g. "3"). This is authoritative once seeded.
#   2. `derive_caller_major` — the transitional `@vN` fallback for a consumer that
#      has not yet been seeded (its first boot, before init writes the file).
# No source → empty MAJOR (the index install drops the version constraint; the
# asset fallback uses releases/latest) — today's behavior for a pure-transport run.
if [ -z "$MAJOR" ] && [ -z "$FROM_SOURCE" ]; then
  if [ -f .release.major.txt ]; then
    _file_major="$(tr -d '[:space:]' < .release.major.txt)"
    if [ -n "$_file_major" ]; then
      MAJOR="v${_file_major}"
      echo "install-release-core: pinned to major line $MAJOR (from .release.major.txt)" >&2
    fi
  fi
  if [ -z "$MAJOR" ]; then
    MAJOR="$(derive_caller_major || true)"
    if [ "$MAJOR" = "v" ]; then MAJOR=""; fi   # no match → sed prefixed an empty line
    [ -n "$MAJOR" ] \
      && echo "install-release-core: pinned to major line $MAJOR (derived from this repo's @vN thin callers; .release.major.txt absent)" >&2
  fi
fi

# The wheel asset name pattern (must match the publish job's output name).
# Two forms: a human-readable one for messages, and a jq-string form whose
# backslash is doubled so it survives embedding in a jq string literal
# (jq parses "\." as an invalid escape; "\\." is a literal-dot regex).
WHEEL_DESC='release_core-*.whl'
WHEEL_JQ_RE='^release_core-.*\\.whl$'

# Emit the single wheel URL for the chosen release, or fail loudly.
#
# Strategy:
#   - no --major: read releases/latest directly (GitHub computes "latest",
#     excluding drafts/prereleases) and pull its wheel asset URLs.
#   - --major vN: list releases (newest-first), drop drafts/prereleases, keep
#     those whose tag is vN or vN.* AND that carry a wheel asset, take the first
#     (newest), emit its wheel URL.
# Either way the result is the array of matching asset URLs; we then require
# exactly one.
resolve_url() {
  urls="$(_resolve_url_list)" || return 1

  n=0
  if [ -n "$urls" ]; then
    n="$(printf '%s\n' "$urls" | grep -c .)"
  fi
  if [ "$n" -eq 0 ]; then
    if [ -n "$MAJOR" ]; then
      echo "install-release-core: no release in major line '$MAJOR' of $REPO carries a wheel asset matching $WHEEL_DESC" >&2
    else
      echo "install-release-core: releases/latest of $REPO has no wheel asset matching $WHEEL_DESC" >&2
    fi
    return 1
  fi
  if [ "$n" -gt 1 ]; then
    echo "install-release-core: expected exactly 1 wheel asset, found $n — release packaging bug:" >&2
    printf '%s\n' "$urls" | sed 's/^/  /' >&2
    return 1
  fi
  printf '%s\n' "$urls"
}

_resolve_url_list() {
  if [ -n "$MAJOR" ]; then
    # Escape dots in the major for the jq regex; double the backslash so it
    # survives the jq string literal. Anchor so `v2` matches v2 / v2.x but not
    # v20.x — `^v2(\.|$)`. per_page=100 (not --paginate) keeps the page
    # deterministic and well past any realistic single-major release count.
    esc="$(printf '%s' "$MAJOR" | sed 's/\./\\\\./g')"
    gh api "repos/${REPO}/releases?per_page=100" --jq "
      [ .[]
        | select(.draft == false and .prerelease == false)
        | select(.tag_name | test(\"^${esc}(\\\\.|\$)\"))
        | select(any(.assets[]; .name | test(\"${WHEEL_JQ_RE}\")))
      ]
      | first
      | .assets[]?
      | select(.name | test(\"${WHEEL_JQ_RE}\"))
      | .browser_download_url
    "
  else
    gh api "repos/${REPO}/releases/latest" --jq "
      .assets[]?
      | select(.name | test(\"${WHEEL_JQ_RE}\"))
      | .browser_download_url
    "
  fi
}

# --from-source path resolution (no release/index resolution). The release_core
# package is NESTED (templates/commons/lib/release_core), and the repo ROOT carries
# a uv-workspace pyproject.toml pip cannot build — so check for the nested package
# FIRST: a checkout root descends to it automatically (release#516); only a path
# without the nested layout is treated as the package dir itself.
if [ -n "$FROM_SOURCE" ]; then
  if [ -f "$FROM_SOURCE/templates/commons/lib/release_core/pyproject.toml" ]; then
    FROM_SOURCE="$FROM_SOURCE/templates/commons/lib/release_core"
  elif [ ! -f "$FROM_SOURCE/pyproject.toml" ]; then
    echo "install-release-core: --from-source '$FROM_SOURCE' has no pyproject.toml (and no nested templates/commons/lib/release_core)" >&2
    exit 1
  fi
fi

# --print-url is a resolve-only probe: from-source → the resolved path; published →
# the asset-fallback wheel URL (the index path has no single upfront URL, and the
# asset URL is what the resolver historically printed). No install, no init.
if [ "$PRINT_URL" -eq 1 ]; then
  if [ -n "$FROM_SOURCE" ]; then
    printf '%s\n' "$FROM_SOURCE"
  else
    resolve_url
  fi
  exit 0
fi

# Build (once) the DEDICATED venv — fully isolated from the user's pip, the system
# site-packages, and any project venv. Reuse an existing venv (fast); recreate only
# if it's missing or broken (e.g. a python upgrade left it dangling).
# Fail fast on a misconfigured VENV_DIR: empty or `/` would make `rm -rf`, the venv
# build, AND the `$VENV_DIR/bin/*` symlink glob below all act on the filesystem root.
if [ -z "$VENV_DIR" ] || [ "$VENV_DIR" = "/" ]; then
  echo "install-release-core: refusing to use invalid VENV_DIR '$VENV_DIR'" >&2
  exit 1
fi
if ! "$VENV_DIR/bin/python" -c 'import sys' >/dev/null 2>&1; then
  rm -rf "$VENV_DIR"
  "$PYTHON" -m venv "$VENV_DIR"
fi

# Install release_core into the venv. Three sources, in order of preference:
#   - --from-source: install the LOCAL tree (release's own CI / canary).
#   - the pip INDEX at the major line (the steady-state path, WS2/WS3).
#   - the GitHub release-ASSET fallback (transitional, kept until WS8) when the
#     index can't resolve a usable wheel.
# `stamp` records the resolved provenance for <venv>/release-source.tag, which
# `release-core init` reads (via sys.prefix) to label the managed-sync auto-commit.
stamp=""
PIP="$VENV_DIR/bin/python -m pip install --disable-pip-version-check"

if [ -n "$FROM_SOURCE" ]; then
  echo "install-release-core: installing $FROM_SOURCE into $VENV_DIR" >&2
  # FAIL-LOUD + transient-retry (WS6/F): a from-source install reads a LOCAL tree but
  # still resolves deps (click) over the network, so wrap it in `retry`; set -e halts
  # on a still-failing install after the retries.
  # shellcheck disable=SC2086
  retry $PIP --force-reinstall "$FROM_SOURCE"
  # Truthful from-source stamp — never fake a tag: "from-source" plus the source
  # checkout's short HEAD when it is a git tree (release's own CI).
  stamp="from-source"
  if sha="$(git -C "$FROM_SOURCE" rev-parse --short HEAD 2>/dev/null)"; then
    stamp="from-source $sha"
  fi
else
  # INDEX-FIRST. The major (e.g. "v3") becomes the version constraint
  # 'release-core>=3,<4'. No major → no constraint (newest the index serves). The
  # index version-compares, so a plain install upgrades to the newest matching
  # wheel — NO --force-reinstall here (the compare already does the right thing).
  installed=0
  if [ -n "$MAJOR" ]; then
    _n="${MAJOR#v}"
    _spec="release-core>=${_n},<$(( _n + 1 ))"
  else
    _spec="release-core"
  fi
  echo "install-release-core: installing '$_spec' from the pip index ($PIP_INDEX_URL)" >&2
  # transient-retry the index install (WS6/F): a network blip must not skip straight
  # to the asset fallback. A genuine "no such version in the index" is deterministic
  # (every retry fails the same way), so this just costs a few seconds before the
  # fallback — acceptable for a load-bearing pull.
  # shellcheck disable=SC2086
  if retry $PIP --extra-index-url "$PIP_INDEX_URL" "$_spec"; then
    installed=1
    stamp="index ${MAJOR:-latest}"
  else
    echo "install-release-core: pip index install failed — falling back to the GitHub release-asset path" >&2
  fi

  # ASSET-PATH FALLBACK (transitional; removed in WS8). The index is empty until
  # this epic ships to main + a release cuts a real tag-stamped wheel — every
  # existing wheel is the static release_core-0.0.1, so the index serves nothing
  # usable until then. resolve_url over the releases API returns the single wheel
  # URL for the chosen line; --force-reinstall (asset path installs a specific URL,
  # no version compare) re-lands the managed tree on a re-run, its long-standing
  # behavior, kept intact here.
  if [ "$installed" -eq 0 ]; then
    # transient-retry the gh-API resolve (WS6/F): `gh api` can blip on the network.
    # A still-failing resolve after the retries is the FAIL-LOUD halt — there is no
    # wheel, so there is no gate; exit non-zero with a clear root-cause message
    # rather than warn-and-continue into an undefined half-state.
    if ! source="$(retry resolve_url)"; then
      echo "install-release-core: FATAL — neither the pip index nor the release-asset fallback could resolve a release_core wheel (after ${RETRY_ATTEMPTS} attempt(s)). The wheel pull is load-bearing: no wheel means no gate. Check network / gh auth (GH_TOKEN) and re-run." >&2
      exit 1
    fi
    echo "install-release-core: installing $source into $VENV_DIR (asset fallback)" >&2
    # shellcheck disable=SC2086
    retry $PIP --force-reinstall "$source"
    # The wheel asset URL is .../releases/download/<tag>/<asset> — the resolved
    # release tag is the second-to-last path segment.
    stamp="${source%/*}"; stamp="${stamp##*/}"
  fi
fi
printf '%s\n' "$stamp" > "$VENV_DIR/release-source.tag"

# Expose the venv's console-scripts on PATH (symlink into BIN_DIR), so the gate
# and the user's shell find `release-core`, `changelog`, `changelog-render`, …
# without the tool venv itself being on PATH. Skip the venv's own internals.
mkdir -p "$BIN_DIR"
for _s in "$VENV_DIR"/bin/*; do
  [ -f "$_s" ] || [ -L "$_s" ] || continue  # files + symlinks only (skip dirs / empty-glob '*')
  _name="$(basename "$_s")"
  case "$_name" in
    python*|pip*|activate*|Activate.ps1|wheel|*.py) continue ;;
  esac
  ln -sf "$_s" "$BIN_DIR/$_name"
done

# Make the exposed scripts reachable — ONE place, every caller. BIN_DIR onto PATH
# for anything this process still does, and, under GitHub Actions, persisted to
# $GITHUB_PATH for later steps. This is the only environment-specific bit, and it
# lives in the script (not re-scripted in each caller / CI yaml): a CI caller just
# invokes the resolver and gets working console-scripts, same as a local session.
case ":$PATH:" in *":$BIN_DIR:"*) : ;; *) PATH="$BIN_DIR:$PATH"; export PATH ;; esac
[ -n "${GITHUB_PATH:-}" ] && printf '%s\n' "$BIN_DIR" >> "$GITHUB_PATH"

if [ "$NO_INIT" -eq 1 ]; then
  echo "install-release-core: installed (--no-init; skipping release-core init)." >&2
  exit 0
fi

# init is best-effort: a failure (e.g. an older published wheel, or a Kind that
# composes no config) must NOT fail the resolver — the install succeeded, and the
# committed tree degrades gracefully. Runs in the CURRENT repo (the boot caller
# cd's to the repo root first).
# A bare `release-core init` is the DEFAULT full install (#476 cutover): it
# installs the WHOLE set of managed files from the wheel bundle (the .release/
# temp dir + every working-tree mirror — skills, configs, per-Kind files, the
# CLAUDE.md header block) and AUTO-COMMITS ONLY the managed paths it wrote, iff
# they actually changed — never `git add -A`, never a user's other staged/unstaged
# work, no-op when byte-identical. This is the pull-model self-sync: it carries
# the whole set, so no push is needed (there is no push mechanism). We pass NO
# flags (auto-commit is the default; do NOT pass --commit — it is redundant and
# rejected in the default full mode) and NOT --push: the commit is made locally
# (riding the current branch, excluded from review as a managed change), and
# SessionStart shouldn't push on the consumer's behalf. init stays best-effort — a
# commit/init failure does NOT fail the resolver.
rc="$VENV_DIR/bin/release-core"
# Build the init arg list as a plain string (NOT a bash array): macOS bash 3.2 +
# `set -u` errors on an empty-array `${arr[@]}` expansion, and the only arg is a
# single literal flag with no whitespace, so word-splitting it is safe + portable.
_init_flag=""
[ "$CLOUD" -eq 1 ] && _init_flag="--cloud"   # cloud-only provisioning (WS5/E)
if [ -x "$rc" ]; then
  echo "install-release-core: installed; running release-core init (full install)" >&2
  # _init_flag is a single controlled literal (--cloud or empty), intentionally split.
  # shellcheck disable=SC2086
  "$rc" init $_init_flag || echo "warning: release-core init failed — managed files not refreshed" >&2
else
  echo "warning: release-core not found in the tool venv ($rc) — skipping init" >&2
fi
