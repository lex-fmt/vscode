#!/usr/bin/env bash
set -euo pipefail

# Canonical npm-stack lint. Prefers the consumer's `lint` script (the
# portfolio convention) and falls back to a bare `npx eslint .` if no
# script is wired but eslint is a dep.
#
# Skip-with-notice if neither path is available.

echo "Running lint..."

if [ -f package.json ] && node -e "process.exit(require('./package.json').scripts && require('./package.json').scripts.lint ? 0 : 1)" 2>/dev/null; then
    npm run --silent lint
elif [ -f package.json ] && node -e "process.exit(require('./package.json').devDependencies && require('./package.json').devDependencies.eslint ? 0 : (require('./package.json').dependencies && require('./package.json').dependencies.eslint ? 0 : 1))" 2>/dev/null; then
    npx --no-install eslint .
else
    echo "No 'lint' script and no eslint dependency — skipping lint."
    exit 0
fi

echo "Lint OK"
