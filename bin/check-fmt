#!/usr/bin/env bash
set -euo pipefail

# Canonical npm-stack format check. Prefers the consumer's
# `format:check` script (the portfolio convention) and falls back to a
# bare `npx prettier --check .` so the script still does the right
# thing on a fresh project that hasn't wired the alias yet.
#
# Skip-with-notice if neither path is available — matches the bats
# Component pattern of "no test infra, no failure".

echo "Checking formatting..."

if [ -f package.json ] && node -e "process.exit(require('./package.json').scripts && require('./package.json').scripts['format:check'] ? 0 : 1)" 2>/dev/null; then
    npm run --silent format:check
elif [ -f package.json ] && node -e "process.exit(require('./package.json').devDependencies && require('./package.json').devDependencies.prettier ? 0 : (require('./package.json').dependencies && require('./package.json').dependencies.prettier ? 0 : 1))" 2>/dev/null; then
    npx --no-install prettier --check .
else
    echo "No 'format:check' script and no prettier dependency — skipping format check."
    exit 0
fi

echo "Formatting OK"
