#!/bin/bash
#
# Pre-commit hook for lex-vscode
# Runs linting, type checking, building, and tests
#

set -e

# Skip in CI. The release workflow (arthur-debert/release/.github/workflows/
# vscode-ext.yml@v1) does `npm ci --omit=dev` before bumping the version and
# committing — dev-only tools (prettier, eslint, tsc) aren't installed, so
# lint-staged would fail with ENOENT. Hooks are for human commits; CI runs
# its own validation separately.
if [ "${CI:-}" = "true" ]; then
    echo "CI=true detected — skipping local pre-commit hook (release pipeline runs its own checks)"
    exit 0
fi

cd "$(git rev-parse --show-toplevel)" || exit 1

REPO_NAME=$(basename "$(pwd)")

echo "Running pre-commit checks for $REPO_NAME..."

# Get available scripts from package.json
has_script() {
    npm pkg get scripts."$1" 2>/dev/null | grep -qv '^{}$'
}

# 1. Run lint-staged (always)
echo ""
echo "Running lint-staged..."
npx lint-staged
echo "Lint-staged OK"

# 2. Type check (if available)
if has_script "typecheck"; then
    echo ""
    echo "Running type check..."
    npm run typecheck
    echo "Type check OK"
fi

# 3. Build
echo ""
echo "Building..."
npm run build
echo "Build OK"

# 4. Run unit tests (integration tests require a semver version in
#    package.json; the full suite runs via `npm test` or in CI)
echo ""
echo "Running unit tests..."
npm run test:unit
echo "Unit tests OK"

echo ""
echo "All pre-commit checks passed!"
