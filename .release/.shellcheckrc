# shellcheck config — applies to every shell file linted in this repo.

# Allow sourcing files from outside the repo (common for setup scripts
# that source env files or shared profile fragments).
external-sources=true

# SC1091: sourced file not found / not following — too noisy for repos
# that source `~/.cargo/env`, `$HOME/.bashrc`, etc., where the file
# exists on the runner but not in static analysis.
disable=SC1091

# Severity floor: info. Surfaces high-value info-level checks —
# notably SC2086 (unquoted expansion) — alongside warnings and errors.
# Only `style`-level nitpicks (SC2250 brace-style, etc.) are kept out.
# This was `warning` during the build-dir migration to unblock the
# fleet; tightened to `info` once every consumer's content was cleaned
# (release#288).
severity=info
