# EditorConfig — portfolio defaults. See https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Tabs are mandatory in Makefiles.
[Makefile]
indent_style = tab

# Rust + TOML community convention: 4-space indents.
[*.{rs,toml}]
indent_size = 4

# Python: PEP 8.
[*.py]
indent_size = 4

# Markdown: two trailing spaces means line break. Don't trim them.
[*.md]
trim_trailing_whitespace = false
