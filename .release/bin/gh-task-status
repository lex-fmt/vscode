#!/usr/bin/env python3
# gh-task-status — read-only PR lifecycle snapshot (release_gh).
#
# Thin shim: put the stdlib-only release_gh package on sys.path and dispatch.
# No install step, so it runs the instant it's symlinked into a consumer's
# .release/ (the package is materialized alongside under lib/release_gh).
import os
import sys

_here = os.path.dirname(os.path.realpath(__file__))
# Normal checkout: bin/<name> is a symlink into templates/commons/bin/, so
# realpath redirects and ../lib/release_gh resolves. GitHub DEREFERENCES the
# symlink when packaging an action (real file at bin/<name>), so ../lib/ misses
# — also try ../templates/commons/lib. (release: action-deref shim fix)
for _rel in ("../lib/release_gh", "../templates/commons/lib/release_gh"):
    _cand = os.path.join(_here, _rel)
    if os.path.isdir(os.path.join(_cand, "release_gh")):
        sys.path.insert(0, _cand)
        break

from release_gh.cli import task_status  # noqa: E402 — sys.path set above

if __name__ == "__main__":
    sys.exit(task_status.main(sys.argv[1:]))
