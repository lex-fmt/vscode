#!/usr/bin/env python3
# gh-task-status — report a PR's dev-loop state + the single next action.
#
# Thin shim (shell→Python): put the
# release_core package on sys.path and dispatch. This is a distributed,
# consumer-facing tool — real source here, symlinked from bin/gh-task-status —
# so realpath lands in templates/commons/bin/ and the package sits at
# ../lib/release_core (the contract's variant (a), like gh-release-issue).
# ORIENTATION.md tells a consumer agent to run `gh-task-status <pr>` FIRST, so
# this shim is what puts the command on the consumer PATH alongside its siblings
# (a console-script entry exists too, but the synced shim is the canonical
# provisioning path — the others all carry one).
import os
import sys

_here = os.path.dirname(os.path.realpath(__file__))
# Normal checkout: bin/<name> is a symlink into templates/commons/bin/, so
# realpath redirects and ../lib/release_core resolves. GitHub DEREFERENCES the
# symlink when packaging an action (real file at bin/<name>), so ../lib/ misses
# — also try ../templates/commons/lib. (release: action-deref shim fix)
for _rel in ("../lib/release_core", "../templates/commons/lib/release_core"):
    _cand = os.path.join(_here, _rel)
    if os.path.isdir(os.path.join(_cand, "release_core")):
        sys.path.insert(0, _cand)
        break

from release_core.prstate.cli import task_status  # noqa: E402 — sys.path set above

if __name__ == "__main__":
    sys.exit(task_status.main(sys.argv[1:]))
