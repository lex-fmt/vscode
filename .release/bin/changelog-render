#!/usr/bin/env python3
# changelog-render — regenerate CHANGELOG.md from CHANGELOG/*.
#
# Thin shim (shell→Python migration, docs/proposals/shell-to-python.md): put the
# stdlib-only release_core package on sys.path and dispatch. Distributed to
# consumers (variant (a)) — realpath lands in templates/commons/bin/, package at
# ../lib/release_core. CLI contract preserved byte-for-byte.
import os
import sys

sys.path.insert(
    0,
    os.path.join(
        os.path.dirname(os.path.realpath(__file__)), "..", "lib", "release_core"
    ),
)

from release_core.verbs import changelog  # noqa: E402 — sys.path set above

if __name__ == "__main__":
    sys.exit(changelog.render_main(sys.argv[1:]))
