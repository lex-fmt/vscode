#!/usr/bin/env python3
# gh-release-issue — file a bug against arthur-debert/release from a consumer.
#
# Thin shim (shell→Python, docs/proposals/shell-to-python.md): put the
# stdlib-only release_core package on sys.path and dispatch. This is a
# distributed tool — real source here, symlinked from bin/gh-release-issue —
# so realpath lands in templates/commons/bin/ and the package sits at
# ../lib/release_core (the contract's variant (a), like gh-task-status). The
# title/body/label and the stdout URL match the old bash byte-for-byte.
import os
import sys

_here = os.path.dirname(os.path.realpath(__file__))
# Normal checkout: bin/<name> is a symlink into templates/commons/bin/, so
# realpath redirects and ../lib/release_core resolves. GitHub DEREFERENCES the
# symlink when packaging an action (real file at bin/<name>), so ../lib/ misses
# — also try ../templates/commons/lib. (release: action-deref shim fix)
for _rel in ("../lib/release_core", "../templates/commons/lib/release_core"):
    _cand = os.path.join(_here, _rel)
    if os.path.isdir(os.path.join(_cand, "release_core")):
        sys.path.insert(0, _cand)
        break

from release_core.verbs import gh_release_issue  # noqa: E402 — sys.path set above

if __name__ == "__main__":
    sys.exit(gh_release_issue.main(sys.argv[1:]))
