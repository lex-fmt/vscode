#!/usr/bin/env python3
# changelog — orchestrator for the changelog-* family.
#
# Thin shim (shell→Python migration, docs/proposals/shell-to-python.md): put the
# stdlib-only release_core package on sys.path and dispatch. changelog is
# distributed to consumers (real file here; bin/changelog is a symlink into
# this dir), so realpath lands in templates/commons/bin/ and the package sits at
# ../lib/release_core (the contract's variant (a)). CLI contract preserved
# byte-for-byte.
import os
import sys

sys.path.insert(
    0,
    os.path.join(
        os.path.dirname(os.path.realpath(__file__)), "..", "lib", "release_core"
    ),
)

from release_core.verbs import changelog  # noqa: E402 — sys.path set above

if __name__ == "__main__":
    sys.exit(changelog.orchestrator_main(sys.argv[1:]))
