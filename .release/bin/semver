#!/usr/bin/env python3
# semver — validate/get edge of the (now removed) vendored bash semver-tool.
#
# Thin shim (shell→Python migration, docs/proposals/shell-to-python.md): put the
# stdlib-only release_core package on sys.path and dispatch. semver is reached
# by the prepare-release composite actions via github.action_path (the bin/semver
# symlink is dereferenced into a real file when GitHub packages the action), so
# realpath may land in templates/commons/bin/ (package at ../lib/release_core) OR
# in bin/ post-deref (package at ../templates/commons/lib/release_core). CLI
# contract preserved byte-for-byte for the validate/get prerel|build operations.
import os
import sys

_here = os.path.dirname(os.path.realpath(__file__))
# Normal checkout: bin/<name> is a symlink into templates/commons/bin/, so
# realpath redirects and ../lib/release_core resolves. GitHub DEREFERENCES the
# symlink when packaging an action (real file at bin/<name>), so ../lib/ misses
# — also try ../templates/commons/lib. (release: action-deref shim fix, #398)
for _rel in ("../lib/release_core", "../templates/commons/lib/release_core"):
    _cand = os.path.join(_here, _rel)
    if os.path.isdir(os.path.join(_cand, "release_core")):
        sys.path.insert(0, _cand)
        break

from release_core.verbs import semver  # noqa: E402 — sys.path set above

if __name__ == "__main__":
    sys.exit(semver.main(sys.argv[1:]))
