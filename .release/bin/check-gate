#!/usr/bin/env bash
# check-gate — run THE pre-commit gate over the whole repo, once.
#
# The single place "run the gate" lives. Every Kind's bin/check calls this
# instead of open-coding the lefthook invocation, so the gate has ONE
# definition — green here means green everywhere (the unified-gate doctrine,
# release#348 + CLAUDE.md "The gate is ONE definition, run everywhere").
#
# Invoked identically by every consumer's bin/check (local), by CI, and by
# release-verify-fleet — one implementation, so there is no copy-paste block
# to drift across Kinds and no Kind that silently skips the gate.
#
# Resolves lefthook from the npm-local install first (node-stack consumers
# vendor it under node_modules/.bin), then a PATH-global install. A missing
# lefthook is a HARD gate failure — the gate does not skip.
#
# Usage:
#   check-gate [extra lefthook args...]
#
# Exit codes:
#   0  — the gate passed
#   1  — the gate failed, or lefthook is not installed (a missing tool is a
#        HARD gate failure — the gate does not skip)
set -euo pipefail

# Resolve against the repo root so node_modules/.bin/lefthook and the gate
# itself bind to this repo regardless of the caller's cwd.
cd "$(cd "$(dirname "$0")" && pwd)/.."

_lefthook=""
if [ -x node_modules/.bin/lefthook ]; then
  _lefthook="node_modules/.bin/lefthook"
elif command -v lefthook >/dev/null 2>&1; then
  _lefthook="lefthook"
else
  echo "error: lefthook not found — run the bootstrap (setup-dev-env.sh / release-core init)" >&2
  exit 1
fi

exec "$_lefthook" run pre-commit --all-files --no-tty "$@"
