#!/usr/bin/env bash
# check-shell — shellcheck ONLY the actual shell files among its arguments.
#
# The single place "lint the shell" lives (the unified gate, release#348 +
# docs/proposals/unified-gate.lex). It selects files by CONTENT — a shell
# shebang, or a .sh/.bash extension — never by path glob. So non-shell files
# that legitimately live under bin/ (the gh-task-status Python shim,
# Dockerfiles, etc.) fall out STRUCTURALLY, instead of via per-file `exclude`
# globs that drift across lefthook invocation modes. Vendored trees under
# */share/ carry their own provenance and are exempt.
#
# Invoked identically by the pre-commit gate, by CI, and by
# release-verify-fleet — one implementation, so a green here means green
# everywhere. It is mode-invariant: it filters whatever file list it is
# handed, so staged-commit and --all-files behave the same.
#
# Usage:
#   check-shell <file>...
#
# Exit codes:
#   0  — every shell file passed (or shellcheck missing, or no shell files)
#   1  — a shell file failed shellcheck
set -euo pipefail

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "shellcheck not installed (skipping; install: see https://github.com/koalaman/shellcheck#installing)" >&2
  exit 0
fi

# Is $1 a shell file we own and should lint?
is_lintable_shell() {
  case "$1" in
    */share/*) return 1 ;; # vendored (carries its own provenance) — exempt
  esac
  # The shebang is AUTHORITATIVE when present: route by interpreter so a
  # .sh/.bash file whose shebang names a shell shellcheck can't handle (zsh,
  # fish, …) is skipped instead of forced through it (consumer#374: a zsh
  # `assets/generate_icons.sh` tripped SC1071). Pure builtins — `read <file`
  # follows symlinks (so a Python shim symlinked into bin/ reads as non-shell
  # and is skipped) and avoids a head+grep subprocess per file, which matters
  # since this runs in a loop over every staged file.
  local first=""
  read -r first < "$1" 2>/dev/null || true
  if [ "${first#'#!'}" != "$first" ]; then
    # Has a shebang → it decides: shellcheck-supported shell ⇒ lint, else skip.
    local shellcheck_shebang='^#!.*[ /](bash|sh|dash|ksh)( |$)'
    if [[ "$first" =~ $shellcheck_shebang ]]; then
      return 0
    fi
    return 1
  fi
  # No shebang → fall back to the .sh/.bash extension.
  case "$1" in
    *.sh | *.bash) return 0 ;;
  esac
  return 1
}

shell_files=()
for f in "$@"; do
  [ -f "$f" ] || continue
  if is_lintable_shell "$f"; then
    shell_files+=("$f")
  fi
done

[ ${#shell_files[@]} -eq 0 ] && exit 0
shellcheck --severity=info -- "${shell_files[@]}"
