# Source files (bundled into out/)
src/**
test/**
out/test/**
shared/src/**
shared/node_modules/**
shared/tsconfig.json

# Comms submodule (only assets needed)
comms/specs/**
comms/docs/**
comms/examples/**
comms/shared/**
comms/.git*
comms/CNAME
comms/.padz

# Build tooling
.github/**
scripts/**
app-bin/**
node_modules/**

# Dev/build-environment dirs that must NEVER ship in the .vsix. The pixi env
# (.pixi/envs/**) materializes the toolchain AND the [artifact-deps] lexd-lsp
# conda package (ARF02-WS04) — it is the STAGING SOURCE, not payload; the
# staged copy lands at resources/lexd-lsp via bundle.stage. dist/ holds the
# built .vsix outputs; .vscode-test/ is the integration suite's downloaded
# VS Code. `vsce package --no-dependencies` (the repo's own smoke-test mode,
# test/runVsixSmoke.ts) walks .vscodeignore alone, so these must be excluded
# here or vsce packages the whole env (and 3.9.x's secret scan chokes on its
# symlinked lib dirs).
.pixi/**
dist/**
.vscode-test/**

# Keep tree-sitter resources (WASM + queries) in VSIX
!resources/tree-sitter-lex.wasm
!resources/tree-sitter.wasm
!resources/queries/**
!resources/embedded-grammars/**

# web-tree-sitter is marked --external in the bundle so the runtime
# `require('web-tree-sitter')` resolves a real file with a usable
# `import.meta.url` (esbuild's CJS bundler stubs it to undefined, which
# breaks Parser.init). Ship just the runtime files; trim the dev surface.
!node_modules/web-tree-sitter/**
node_modules/web-tree-sitter/debug/**
node_modules/web-tree-sitter/lib/**
node_modules/web-tree-sitter/src/**
node_modules/web-tree-sitter/*.map
node_modules/web-tree-sitter/*.d.ts
node_modules/web-tree-sitter/README.md

*.ts
!*.d.ts
tsconfig.json
eslint.config.mjs
.gitignore

# Development files
*.log
*.map
.env*
.temp
.tmp

# Test artifacts
test_output.log
coverage/**
