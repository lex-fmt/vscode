#!/usr/bin/env bash
# update-release <new-version> — apply <new-version> across this repo's
# release-touched files and `git add` everything modified. Does NOT commit;
# the caller commits.
#
# Touched files in this repo:
#   - package.json        ("version" field via jq)
#   - CHANGELOG.md        (rename `## Unreleased` -> `## vX.Y.Z (YYYY-MM-DD)`
#                          and insert a fresh `## Unreleased` block above; or,
#                          if no `## Unreleased` near the top, insert a new
#                          `## vX.Y.Z (YYYY-MM-DD)` section directly under the
#                          `# Changelog` title)
#   - comms (submodule)   (fast-forward to origin/main)
#   - shared/lex-deps.json (sync `lexd-lsp` and `tree-sitter` to the latest
#                           releases of lex-fmt/lex and lex-fmt/tree-sitter-lex)
#
# Usage: ./scripts/release/update-release 0.11.0
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <new-version>" >&2
  echo "       <new-version> is bare (no leading 'v'), e.g. 0.11.0" >&2
  exit 2
fi

new_version="$1"

# Sanity: refuse a leading `v` to keep CLI contract consistent.
if [[ "$new_version" =~ ^v ]]; then
  echo "error: pass the bare version (no leading 'v'); got '$new_version'" >&2
  exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$repo_root"

today="$(date +%Y-%m-%d)"

# --- 1. package.json ---------------------------------------------------------
tmp_pkg="$(mktemp)"
jq --arg v "$new_version" '.version = $v' package.json > "$tmp_pkg"
mv "$tmp_pkg" package.json
git add package.json

# --- 2. CHANGELOG.md ---------------------------------------------------------
# If there is an `## Unreleased` heading within the first ~30 lines, rename it
# in place and prepend a fresh `## Unreleased` block above.  Otherwise insert a
# brand-new release section directly under the `# Changelog` title line.
changelog="CHANGELOG.md"
if [[ -f "$changelog" ]]; then
  # Look for `## Unreleased` near the top (line <= 30).
  unreleased_line="$(awk '/^## Unreleased[[:space:]]*$/{print NR; exit}' "$changelog" || true)"
  if [[ -n "$unreleased_line" && "$unreleased_line" -le 30 ]]; then
    # Rename existing top `## Unreleased` -> `## vX.Y.Z (YYYY-MM-DD)`, then
    # insert a new `## Unreleased\n\n` block above it.
    python3 - "$changelog" "$new_version" "$today" "$unreleased_line" <<'PY'
import sys, pathlib
path = pathlib.Path(sys.argv[1])
version = sys.argv[2]
today = sys.argv[3]
line_no = int(sys.argv[4])  # 1-based
text = path.read_text()
lines = text.splitlines(keepends=True)
idx = line_no - 1
# Replace the line "## Unreleased" with the new versioned heading.
lines[idx] = f"## v{version} ({today})\n"
# Insert a fresh `## Unreleased` block (heading + blank line) above it.
insert = ["## Unreleased\n", "\n"]
lines[idx:idx] = insert
path.write_text("".join(lines))
PY
  else
    # No usable `## Unreleased` at the top — just inject a new release header
    # directly after the `# Changelog` title.
    python3 - "$changelog" "$new_version" "$today" <<'PY'
import sys, pathlib
path = pathlib.Path(sys.argv[1])
version = sys.argv[2]
today = sys.argv[3]
text = path.read_text()
lines = text.splitlines(keepends=True)
# Find the `# Changelog` title; insert two lines (blank + new section header
# + blank) after it.  Falls back to prepending if the title is missing.
insert_at = None
for i, line in enumerate(lines):
    if line.strip() == "# Changelog":
        insert_at = i + 1
        break
if insert_at is None:
    new_block = [f"## v{version} ({today})\n", "\n"]
    lines = new_block + lines
else:
    # Skip a single immediately-following blank line if present, so the new
    # heading slots in right after the `# Changelog` title with exactly one
    # blank line above it.
    if insert_at < len(lines) and lines[insert_at].strip() == "":
        insert_at += 1
    new_block = [f"## v{version} ({today})\n", "\n"]
    lines[insert_at:insert_at] = new_block
path.write_text("".join(lines))
PY
  fi
  git add "$changelog"
fi

# --- 3. comms submodule ------------------------------------------------------
if [[ -d comms/.git || -f comms/.git ]]; then
  (cd comms && git fetch origin && git checkout origin/main)
  git add comms
fi

# --- 4. shared/lex-deps.json -------------------------------------------------
deps_file="shared/lex-deps.json"
if [[ -f "$deps_file" ]]; then
  if ! lex_latest="$(gh release view --repo lex-fmt/lex --json tagName --jq .tagName)"; then
    echo "error: could not fetch latest release from lex-fmt/lex" >&2
    exit 1
  fi
  if ! ts_latest="$(gh release view --repo lex-fmt/tree-sitter-lex --json tagName --jq .tagName)"; then
    echo "error: could not fetch latest release from lex-fmt/tree-sitter-lex" >&2
    exit 1
  fi

  tmp_deps="$(mktemp)"
  jq --arg lex "$lex_latest" --arg ts "$ts_latest" \
    '.["lexd-lsp"] = $lex | .["tree-sitter"] = $ts' \
    "$deps_file" > "$tmp_deps"
  mv "$tmp_deps" "$deps_file"
  git add "$deps_file"
fi

echo "update-release: staged changes for v$new_version" >&2
echo "  package.json -> $new_version" >&2
echo "  CHANGELOG.md -> new v$new_version ($today) section" >&2
if [[ -d comms/.git || -f comms/.git ]]; then
  echo "  comms        -> origin/main" >&2
fi
if [[ -f "$deps_file" ]]; then
  echo "  $deps_file -> lexd-lsp=$lex_latest, tree-sitter=$ts_latest" >&2
fi
