#!/usr/bin/env bash
# trigger-release <new-version>
#
# Layer 0 release-trigger primitive for lex-fmt/vscode.
#
# Role:
#   This is one of the small, single-purpose release primitives that the
#   higher-level release orchestrator composes. Its sole job is to fire the
#   release CI workflow for a version that has already been prepared (version
#   bumps committed and merged into main via a version-bump PR).
#
# Strategy:
#   vscode uses the *workflow_dispatch* release strategy via the canonical
#   arthur-debert/release/.github/workflows/vscode-ext.yml@v1 thin caller in
#   .github/workflows/release.yml. The reusable workflow handles the
#   version bump, changelog roll, tag + push, and GH release creation — so
#   this primitive does not tag locally. It just fires the workflow_dispatch
#   event with the requested version, and the workflow does the rest.
#
#   Migration note (2026-05-18): the previous strategy was tag-push (release
#   triggered by `on: push: tags: 'v*'`). Migration to release@v1.3.0 moved
#   the trigger contract to workflow_dispatch — matching the cross-repo
#   cascade-handler contract. The orchestrator at arthur-debert/release/
#   bin/release-lex now drives all consumers through workflow_dispatch.
#
# Typical call site:
#   The orchestrator invokes this script with the target version. There is
#   no longer a "you must be on the right commit" precondition — the
#   reusable workflow always bumps from main HEAD.
#
# See tracking issue: lex-fmt/lex#640.
set -euo pipefail

# Dependency check — matches the per-repo convention used by
# scripts/release/should-release.
if ! command -v gh >/dev/null 2>&1; then
  echo "error: gh is required but not installed" >&2
  exit 1
fi

usage() {
  echo "Usage: $(basename "$0") <new-version>" >&2
  echo "  new-version   Bare semver string, e.g. 0.11.0 (no leading v)" >&2
}

[[ $# -ne 1 ]] && { usage; exit 2; }
NEW_VERSION="$1"
if ! [[ "$NEW_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?$ ]]; then
  echo "error: version must be X.Y.Z[-PRERELEASE]" >&2
  exit 2
fi

echo "Triggering release workflow for v${NEW_VERSION}..."
gh workflow run release.yml -f "version=${NEW_VERSION}"
echo "Done. CI should pick it up shortly."
echo "Watch: gh run list --workflow=release.yml --limit 1"
