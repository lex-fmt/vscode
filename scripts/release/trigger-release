#!/usr/bin/env bash
# trigger-release <new-version>
#
# Layer 0 release-trigger primitive for lex-fmt/vscode.
#
# Role:
#   This is one of the small, single-purpose release primitives that the
#   higher-level release orchestrator composes. Its sole job is to fire the
#   release CI workflow for a version that has already been prepared (version
#   bumps committed and merged into main via a version-bump PR).
#
# Strategy:
#   vscode uses the *tag-push* release strategy. The release CI workflow is
#   configured with `on: push: tags: [v*]`, so creating and pushing an
#   annotated-or-lightweight `vX.Y.Z` tag is what kicks off the build,
#   packaging, and publish steps. There is no `workflow_dispatch` button to
#   click and no separate "release" branch — the tag *is* the trigger.
#
# Typical call site:
#   The orchestrator invokes this script after a version-bump PR has merged
#   into main and the local checkout is on the merge commit. Running it from
#   any other commit would tag the wrong revision, so callers are responsible
#   for positioning HEAD first.
#
# See tracking issue: lex-fmt/lex#640.
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <new-version>" >&2
  echo "  new-version   Bare semver string, e.g. 0.10.1 (no leading v)" >&2
}

[[ $# -ne 1 ]] && { usage; exit 2; }
NEW_VERSION="$1"
[[ ! "$NEW_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] && { echo "error: version must be X.Y.Z" >&2; exit 2; }

TAG="v$NEW_VERSION"
if git rev-parse "$TAG" >/dev/null 2>&1; then
  echo "error: tag $TAG already exists locally — delete it or pick a new version" >&2
  exit 1
fi

echo "Tagging $TAG on $(git rev-parse --short HEAD)..."
git tag "$TAG"
echo "Pushing $TAG to origin..."
git push origin "$TAG"
echo "Done. CI should pick it up shortly."
