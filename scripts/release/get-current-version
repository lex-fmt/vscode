#!/usr/bin/env bash
# get-current-version — print this repo's current version (bare, no `v` prefix).
#
# Source of truth: package.json `"version"`. However, this repo carries
# `0.0.0-dev` in package.json (release CI rewrites at publish time), so when
# that placeholder is present we fall back to the latest `vX.Y.Z` git tag.
#
# Usage: ./scripts/release/get-current-version
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$repo_root"

pkg_version="$(jq -r '.version' package.json)"

if [[ "$pkg_version" == "0.0.0-dev" || -z "$pkg_version" || "$pkg_version" == "null" ]]; then
  # Fall back to the latest semver tag.
  tag="$(git describe --tags --abbrev=0 --match='v*.*.*' 2>/dev/null || true)"
  if [[ -z "$tag" ]]; then
    echo "error: package.json has no usable version and no vX.Y.Z tags found" >&2
    exit 1
  fi
  echo "${tag#v}"
else
  echo "$pkg_version"
fi
